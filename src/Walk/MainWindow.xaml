<ui:FluentWindow
    x:Class="Walk.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:Walk.Helpers"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Walk"
    Width="680"
    MinHeight="56"
    MaxHeight="580"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="False"
    Topmost="True"
    ResizeMode="NoResize"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round">

    <ui:FluentWindow.Resources>
        <helpers:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <helpers:ZeroCountToVisibilityConverter x:Key="ZeroCountToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Completely naked TextBox: nuke ALL chrome from the ControlTemplate -->
        <Style x:Key="NakedTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer
                            x:Name="PART_ContentHost"
                            Focusable="False"
                            HorizontalScrollBarVisibility="Hidden"
                            VerticalScrollBarVisibility="Hidden"
                            Padding="0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Result list item with accent bar on selection -->
        <Style x:Key="ResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border
                                x:Name="AccentBar"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Width="3"
                                Height="16"
                                CornerRadius="1.5"
                                Margin="0,0,0,0"
                                Opacity="0">
                                <Border.Background>
                                    <SolidColorBrush x:Name="AccentBrush" Color="{DynamicResource SystemAccentColorSecondary}" />
                                </Border.Background>
                            </Border>

                            <Border
                                x:Name="ItemChrome"
                                CornerRadius="6"
                                Padding="12,8"
                                Margin="6,1,4,1">
                                <Border.Background>
                                    <SolidColorBrush x:Name="ItemBg" Color="Transparent" />
                                </Border.Background>
                                <ContentPresenter />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ItemBg" Storyboard.TargetProperty="Color" To="#0CFFFFFF" Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ItemBg" Storyboard.TargetProperty="Color" To="Transparent" Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ItemBg" Storyboard.TargetProperty="Color" To="#0FFFFFFF" Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="AccentBar" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="ItemBg" Storyboard.TargetProperty="Color" To="Transparent" Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="AccentBar" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KbdBadge" TargetType="Border">
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="5,2,5,3" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="KbdText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="HintLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="4,0,0,0" />
        </Style>

        <Storyboard x:Key="SearchDotStoryboard" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SearchDot1" Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.28" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.16" Value="1" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.48" Value="0.28" />
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.72" Value="0.28" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SearchDot2" Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.28" />
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="0.28" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.28" Value="1" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0.28" />
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.72" Value="0.28" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SearchDot3" Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.28" />
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.24" Value="0.28" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.72" Value="0.28" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </ui:FluentWindow.Resources>

    <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="RootScaleTransform" ScaleX="1" ScaleY="1" />
        </Grid.RenderTransform>

        <DockPanel LastChildFill="True">

            <Border
                DockPanel.Dock="Bottom"
                Padding="14,7,14,9"
                BorderThickness="0,1,0,0"
                BorderBrush="#0AFFFFFF"
                Visibility="{Binding Results.Count, Converter={StaticResource CountToVisibilityConverter}}">
                <Grid>
                    <ItemsControl ItemsSource="{Binding VisibleActions}" HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                    <Border Style="{StaticResource KbdBadge}">
                                        <TextBlock Text="{Binding DisplayKeyGesture}" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <TextBlock Text="{Binding DisplayLabel}" Style="{StaticResource HintLabel}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource KbdBadge}">
                                <TextBlock Text="Esc" Style="{StaticResource KbdText}" />
                            </Border>
                            <TextBlock Text="Close" Style="{StaticResource HintLabel}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel>

                <Grid Margin="8,12,12,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:SymbolIcon
                        Symbol="Search24"
                        FontSize="22"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0" />

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            Text="Search apps, type > for Run, or browse C:\ paths..."
                            FontSize="20"
                            Foreground="{DynamicResource TextFillColorDisabledBrush}"
                            IsHitTestVisible="False"
                            VerticalAlignment="Center"
                            Visibility="{Binding Text.Length, ElementName=SearchBox, Converter={StaticResource ZeroCountToVisibilityConverter}}" />

                        <TextBox
                            x:Name="SearchBox"
                            Style="{StaticResource NakedTextBox}"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <StackPanel
                        Grid.Column="2"
                        Margin="16,0,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource SearchDotStoryboard}" />
                                </EventTrigger>
                            </StackPanel.Triggers>
                            <Border
                                x:Name="SearchDot1"
                                Width="5"
                                Height="5"
                                Margin="0,0,4,0"
                                CornerRadius="2.5"
                                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                Opacity="0.28" />
                            <Border
                                x:Name="SearchDot2"
                                Width="5"
                                Height="5"
                                Margin="0,0,4,0"
                                CornerRadius="2.5"
                                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                Opacity="0.28" />
                            <Border
                                x:Name="SearchDot3"
                                Width="5"
                                Height="5"
                                CornerRadius="2.5"
                                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                Opacity="0.28" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Visibility="{Binding Results.Count, Converter={StaticResource CountToVisibilityConverter}}">

                    <Rectangle Height="1" Fill="#0AFFFFFF" Margin="14,0" />

                    <ListBox
                        x:Name="ResultsList"
                        ItemsSource="{Binding Results}"
                        SelectedIndex="{Binding SelectedIndex}"
                        MaxHeight="420"
                        Margin="4,4,4,4"
                        BorderThickness="0"
                        Background="Transparent"
                        ScrollViewer.CanContentScroll="True"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling"
                        ItemContainerStyle="{StaticResource ResultItemStyle}"
                        FocusVisualStyle="{x:Null}">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Grid
                                        Grid.Column="0"
                                        Width="32"
                                        Height="32"
                                        VerticalAlignment="Center">
                                        <Border CornerRadius="8" Background="#12FFFFFF">
                                            <TextBlock
                                                Text="{Binding DisplayIconGlyph}"
                                                FontSize="15"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </Border>

                                        <Image
                                            Source="{Binding Icon}"
                                            Width="32"
                                            Height="32"
                                            RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Grid>

                                    <StackPanel Grid.Column="1" Margin="14,0,8,0" VerticalAlignment="Center">
                                        <TextBlock
                                            Text="{Binding Title}"
                                            FontSize="13"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Text="{Binding Subtitle}"
                                            FontSize="11.5"
                                            Margin="0,1,0,0"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Text="{Binding PluginName}"
                                        FontSize="10"
                                        Foreground="{DynamicResource TextFillColorDisabledBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

            </StackPanel>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
